{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@app/utils/*": ["./utils/src/*"],
      "@app/utils": ["./utils/src/index.ts"],
      "@app/nest/*": ["./nest/src/*"],
      "@app/env": ["./env/src/index.ts"],
      "@app/env/*": ["./env/src/*"],
      "@app/effect": ["./effect/index.ts"],
      "@app/effect/*": ["./effect/*"],
      "@app/features/*": ["./features/*"],
      "@/*": ["./*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
