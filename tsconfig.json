{
  "$schema": "https://json.schemastore.org/tsconfig",
  "_comment": "libs 不能用 extends tsconfig.base.json — Bun 在嵌套 tsconfig + extends 时 paths 解析失败",
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "preserve",
    "moduleDetection": "force",
    "allowJs": true,
    "noEmit": true,

    "strict": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,

    "paths": {
      "@app/utils/*": ["./utils/src/*"],
      "@app/utils": ["./utils/src/index.ts"],
      "@app/nest/*": ["./nest/src/*"],
      "@app/env": ["./env/src/index.ts"],
      "@app/env/*": ["./env/src/*"],
      "@app/effect": ["./effect/index.ts"],
      "@app/effect/*": ["./effect/*"],
      "@app/features/*": ["./features/*"],
      "@/*": ["./*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
